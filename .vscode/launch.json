{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug EqV3 Training (Single GPU)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/my_main.py",
            "console": "integratedTerminal",
            "args": [
                "--num-gpus", "1",
                "--amp",
                "--mode", "train",
                "--config-yml", "experimental/configs/oc20/200k/equiformer_v3/experiments/debuggg.yml",
                "--run-dir", "models/oc20/equiformer_v3_debug/200k",
                "--print-every", "200",
                "--seed", "1",
                "--identifier", "base",
                "--optim.eval_every=5000",
                "--optim.batch_size=8",
                "--optim.eval_batch_size=16",
                "--optim.grad_accumulation_steps=1"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "1"
            },
            "justMyCode": true
        }
    ]
}